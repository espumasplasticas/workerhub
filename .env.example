APP_NAME=WorkerHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:5010
APP_PORT=5010

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlsrv
DB_HOST=192.168.0.74
DB_PORT=1433
DB_DATABASE=workerhub
DB_USERNAME=
DB_PASSWORD=
DB_ENCRYPT=no
DB_TRUST_SERVER_CERTIFICATE=true
DB_LOGIN_TIMEOUT=30
DB_CONNECT_RETRY_COUNT=3
DB_CONNECT_RETRY_INTERVAL=10
DB_ADMIN_HOST=192.168.0.74
DB_ADMIN_PORT=1433
DB_ADMIN_DATABASE=master
DB_ADMIN_USERNAME=
DB_ADMIN_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

WORKERHUB_DEFAULT_QUEUE=migration-default
WORKERHUB_HIGH_PRIORITY_QUEUE=migration-high
WORKERHUB_INTEGRATION_QUEUE=integration
WORKERHUB_RECEIPTS_QUEUE=receipts-default
WORKERHUB_RECEIPTS_HIGH_QUEUE=receipts-high
WORKERHUB_SALES_ORDERS_QUEUE=sales-orders-default
WORKERHUB_SALES_ORDERS_HIGH_QUEUE=sales-orders-high
WORKERHUB_INVOICES_QUEUE=invoices-default
WORKERHUB_INVOICES_HIGH_QUEUE=invoices-high
WORKERHUB_CUSTOMERS_QUEUE=customers-default
WORKERHUB_CUSTOMERS_HIGH_QUEUE=customers-high
WORKERHUB_GENERAL_QUEUE=general-default
WORKERHUB_GENERAL_HIGH_QUEUE=general-high
WORKERHUB_DOCUMENT_MIGRATION_QUEUE=migration-default
WORKERHUB_DOCUMENT_MIGRATION_HIGH_QUEUE=migration-high
WORKERHUB_DOCUMENT_MIGRATION_TRIES=3
WORKERHUB_DOCUMENT_MIGRATION_TIMEOUT=300
WORKERHUB_RECEIPTS_RUNTIME=php
WORKERHUB_SALES_ORDERS_RUNTIME=php
WORKERHUB_INVOICES_RUNTIME=php
WORKERHUB_CUSTOMERS_RUNTIME=python
WORKERHUB_GENERAL_RUNTIME=php
WORKERHUB_NOTIFICATIONS_ENABLED=true
WORKERHUB_NOTIFY_ON_COMPLETED=false
WORKERHUB_NOTIFY_ON_FAILED=true
WORKERHUB_NOTIFICATION_EMAILS=
WORKERHUB_NOTIFICATION_USER_IDS=

KAFKA_BROKERS=127.0.0.1:19092
KAFKA_CLIENT_ID=workerhub
KAFKA_PUBLISH_ENABLED=true
WORKERHUB_KAFKA_DIRECT_DISPATCH_FALLBACK=false
WORKERHUB_KAFKA_SUPPRESS_PUBLISH_FAILURES=false
KAFKA_CONSUMER_GROUP=workerhub-task-consumers
KAFKA_TOPIC_REQUESTS=workerhub.tasks.requests
KAFKA_TOPIC_RESULTS=workerhub.tasks.results
KAFKA_TOPIC_FAILURES=workerhub.tasks.failures
KAFKA_TOPIC_DEAD_LETTERS=workerhub.tasks.dead_letters
KAFKA_TOPIC_EXTERNAL_EXECUTION_PREFIX=workerhub.runtime
KAFKA_TOPIC_RECEIPTS_EXECUTION=workerhub.runtime.php.receipts
KAFKA_TOPIC_SALES_ORDERS_EXECUTION=workerhub.runtime.php.sales_orders
KAFKA_TOPIC_INVOICES_EXECUTION=workerhub.runtime.php.invoices
KAFKA_TOPIC_CUSTOMERS_EXECUTION=workerhub.runtime.python.customers
KAFKA_TOPIC_GENERAL_EXECUTION=workerhub.runtime.php.general
WORKERHUB_BROADCAST_CHANNEL=workerhub.monitor
WORKERHUB_TASK_BROADCAST_PREFIX=workerhub.tasks
WORKERHUB_OPERATIONS_TOKEN=
WORKERHUB_RUNTIME_SHARED_TOKEN=
WORKERHUB_OPERATIONS_ALLOWED_EMAILS=
WORKERHUB_ALLOW_TOKEN_FALLBACK=true
WORKERHUB_ALLOW_LOCAL_BYPASS=true
WORKERHUB_DEAD_LETTERS_ALERT_THRESHOLD=25
# Opcional: activar solo si quieres validar el cruce antes del WS, no es el comportamiento legacy.
WORKERHUB_RECEIPT_CROSS_REFERENCE_GUARD_ENABLED=false
WORKERHUB_RECEIPT_CROSS_REFERENCE_MODE=strict
WORKERHUB_ORDER_DETAILS_TABLE=pos.pedidos_detalle
WORKERHUB_ORDER_LEGACY_VERIFICATION_THRESHOLD=1000

API_BASE_URL=https://api3dev.comodisimos.com
# Produccion: https://api3.comodisimos.com
API_RECEIPT_MIGRATION_NOTIFICATIONS_ENDPOINT=/api/internal/workerhub/receipts/migrated
API_ORDER_MIGRATION_NOTIFICATIONS_ENDPOINT=/api/internal/workerhub/orders/migrated
API_TIMEOUT_SECONDS=10
API_WORKERHUB_NOTIFICATION_TOKEN=
BACKOFFICE_BASE_URL=https://apibackofficedev.comodisimos.com
# Produccion: https://apibackoffice.comodisimos.com
BACKOFFICE_AUTH_ENDPOINT=/api/internal/workerhub/operators/authenticate
BACKOFFICE_HEALTH_ENDPOINT=/api/internal/workerhub/operators/health
BACKOFFICE_AUTH_TIMEOUT=5
BACKOFFICE_ADMIN_ROLE_ID=20
BACKOFFICE_SHARED_TOKEN=

HORIZON_ALLOWED_EMAILS=

EPSA_SIESA_SOAP_URL=
EPSA_SIESA_SOAP_USER=
EPSA_SIESA_SOAP_PASSWORD=
EPSA_SIESA_SOAP_CONNECTION=
EPSA_SIESA_SOAP_COMPANY_ID=1
EPSA_SIESA_CREATE_FLAT_FILE=true
EPSA_SIESA_FLAT_FILE_DIRECTORY=/var/www/html/storage/app/epsa_library
EPSA_SIESA_PUBLISHER=null
EPSA_SIESA_PUBLISH_DIRECTORY=

