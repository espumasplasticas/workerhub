APP_NAME=WorkerHub
APP_ENV=testing
APP_KEY=base64:TESTINGKEYXXXXXXXXXXXXXXXXXXXXXXXXXXXXX==
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack
LOG_LEVEL=debug

# Use SQLite for local tests to avoid touching any MySQL/SQLServer databases
DB_CONNECTION=sqlite
DB_DATABASE=database/testing.sqlite
DB_FOREIGN_KEYS=true

CACHE_DRIVER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array

MAIL_MAILER=array
TELESCOPE_ENABLED=false

# WorkerHub/infra flags - disable external integration for safe local tests
WORKERHUB_ALLOW_LOCAL_BYPASS=true
WORKERHUB_ALLOW_TOKEN_FALLBACK=true
KAFKA_PUBLISH_ENABLED=false
WORKERHUB_KAFKA_DIRECT_DISPATCH_FALLBACK=false
WORKERHUB_KAFKA_SUPPRESS_PUBLISH_FAILURES=true

# Misc (keep defaults safe)
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# If your tests require other services, prefer to mock them instead of enabling real connections.
