APP_ENV=testing
APP_DEBUG=false

# Nunca usar SQL Server reales para pruebas de WorkerHub.
# Las pruebas deben usar solo la base mysql local de testing.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=workerhub_test
DB_USERNAME=root
DB_PASSWORD=

CACHE_DRIVER=array
QUEUE_CONNECTION=sync
SESSION_DRIVER=array
MAIL_MAILER=array
TELESCOPE_ENABLED=false

WORKERHUB_ALLOW_LOCAL_BYPASS=true
WORKERHUB_ALLOW_TOKEN_FALLBACK=true
KAFKA_PUBLISH_ENABLED=true
WORKERHUB_KAFKA_DIRECT_DISPATCH_FALLBACK=false
WORKERHUB_KAFKA_SUPPRESS_PUBLISH_FAILURES=false
